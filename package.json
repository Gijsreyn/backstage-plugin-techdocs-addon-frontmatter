{
  "name": "backstage-plugin-techdocs-addon-frontmatter",
  "version": "0.1.1",
  "configSchema": "config.d.ts",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "typesVersions": {
    "*": {
      "alpha": [
        "src/alpha.ts"
      ],
      "package.json": [
        "package.json"
      ]
    }
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "main": "dist/index.esm.js",
    "types": "dist/index.d.ts",
    "registry": "https://registry.npmjs.org"
  },
  "backstage": {
    "role": "frontend-plugin-module",
    "pluginId": "techdocs",
    "pluginPackage": "@backstage/plugin-techdocs"
  },
  "keywords": [
    "backstage",
    "techdocs",
    "frontmatter",
    "yaml"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./alpha": "./src/alpha.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "start": "backstage-cli package start",
    "build": "backstage-cli package build",
    "lint": "backstage-cli package lint",
    "test": "backstage-cli package test",
    "clean": "backstage-cli package clean",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack",
    "tsc": "tsc",
    "tsc:full": "tsc --skipLibCheck false --incremental false"
  },
  "dependencies": {
    "@backstage/core-components": "^0.18.11",
    "@backstage/core-plugin-api": "^1.12.7",
    "@backstage/frontend-plugin-api": "^0.17.2",
    "@backstage/plugin-techdocs-react": "^1.3.6",
    "@material-ui/core": "^4.12.2"
  },
  "peerDependencies": {
    "@types/react": "^17.0.0 || ^18.0.0",
    "react": "^17.0.0 || ^18.0.0",
    "react-dom": "^17.0.0 || ^18.0.0",
    "react-router-dom": "^6.3.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.3",
    "@backstage/cli-defaults": "^0.1.3",
    "@backstage/core-app-api": "^1.19.0",
    "@backstage/dev-utils": "^1.1.16",
    "@backstage/test-utils": "^1.7.11",
    "@jest/environment-jsdom-abstract": "30",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^27",
    "@types/react": "^18.3.12",
    "@types/react-dom": "*",
    "jest": "~30.2.0",
    "jsdom": "27",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.2",
    "typescript": "~5.8.0"
  },
  "files": [
    "dist",
    "config.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Gijsreyn/backstage-plugin-techdocs-addon-frontmatter",
    "directory": "."
  },
  "bugs": {
    "url": "https://github.com/Gijsreyn/backstage-plugin-techdocs-addon-frontmatter/issues"
  },
  "homepage": "https://github.com/Gijsreyn/backstage-plugin-techdocs-addon-frontmatter#readme",
  "author": "Gijs Reijn",
  "packageManager": "yarn@4.8.1"
}
